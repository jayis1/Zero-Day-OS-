# =============================================================================
# ZERO-DAY OS — .gitignore
# =============================================================================

# ── pi-gen build artifacts ──────────────────────────────────────────────────
# The entire pi-gen work directory is generated by the build and can be
# recreated from source. The Docker container and all intermediate artifacts
# should never be committed.

pi-gen/work/
pi-gen/deploy/
pi-gen/stage0/rootfs/
pi-gen/stage1/rootfs/
pi-gen/stage2/rootfs/
pi-gen/stage3/rootfs/
pi-gen/stage4/rootfs/
pi-gen/stage5/rootfs/
pi-gen/export-image/rootfs/
pi-gen/export-image/*/rootfs/

# Docker container state (preserved between builds for debugging)
# Uncomment if you want to track the Dockerfile but not container data:
# pi-gen/.docker/

# Build logs
pi-gen/*.log
pi-gen/build.log

# ── Compiled device tree overlays ─────────────────────────────────────────
# .dtbo files are compiled from .dts sources — never commit binaries

overlays/*.dtbo

# ── Kernel build artifacts ──────────────────────────────────────────────────

kernel/*.ko
kernel/*.o
kernel/*.cmd
kernel/Module.symvers
kernel/modules.order
kernel/modules.builtin
kernel/.config
kernel/.tmp_versions/
kernel/source/            # kernel source tree if downloaded

# ── Captured data and loot ─────────────────────────────────────────────────
# These are runtime artifacts — handshakes, captures, logs, etc.

handshakes/
pmkid/
loot/
captures/
pcaps/
wardrives/

# ── OS artifacts ───────────────────────────────────────────────────────────

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Editor / IDE artifacts ─────────────────────────────────────────────────

*.swp
*.swo
*.swn
*~
.project
.classpath
.settings/
.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace

# ── Python artifacts ───────────────────────────────────────────────────────

__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
ENV/
env/
.python-version
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ── JanOS-app (installed on-demand, not tracked) ──────────────────────────

janos-app/
/opt/cardputer/janos-app/

# ── Firmware binaries (downloaded on-demand) ──────────────────────────────

*.bin
*.elf
*.hex
*.fw
firmware/

# ── Disk images (generated by build) ─────────────────────────────────────

*.img
*.img.xz
*.img.gz
*.img.zip
*.qcow2
*.vmdk
*.vhd

# ── Temporary and log files ────────────────────────────────────────────────

*.log
*.tmp
*.temp
*.bak
*.orig
*.rej
*.pid
*.lock
nohup.out

# ── Secrets (never commit these) ──────────────────────────────────────────

.env
.env.*
credentials
credentials.*
*.pem
*.key
*.p12
*.pfx
*.jks
secrets/
.wpa_supplicant
hostapd.conf
wpapsk.*

# ── Screenshots and media (already in repo, but ignore new ones) ──────────
# We track the original screenshots but ignore accidental new ones that
# might contain sensitive information from real targets.

# Uncomment the following to ignore all screenshots:
# Screenshot_*.png
# Screenshot_*.jpg
# *.mov
# *.mp4
# *.avi

# ── Network capture files (from real targets) ─────────────────────────────

*.cap
*.pcap
*.pcapng
*.netxml
*.kismet
*.log.csv
*.csv
*.kml

# ── Wordlist caches (large generated files) ───────────────────────────────

*.hashdb
*.pot
*.hcstat

# ── ESP32 / MonsterC5 build artifacts ────────────────────────────────────

build/
sdkconfig.old
sdkconfig.*

# ── Miscellaneous ──────────────────────────────────────────────────────────

*.core
*.stackdump
node_modules/
.npm/
yarn.lock
package-lock.json