# stage0/ files directory
# The Raspberry Pi GPG keyring must be placed here before building.
# Download with:
#   curl -o stage0/files/raspberrypi.gpg https://www.raspberrypi.com/raspberrypi.gpg.key
# Or export from your system:
#   gpg --dearmor < /usr/share/keyrings/raspberrypi-archive-keyring.gpg > stage0/files/raspberrypi.gpg
#
# If you're building on a system that already has Raspberry Pi OS keys:
#   cp /usr/share/keyrings/raspberry-pi-archive-keyring.gpg stage0/files/raspberrypi.gpg