# Kernel config fragment for ZERO-DAY OS
# Based on bcm2837_defconfig with modifications for Cardputer Zero
# Apply with: scripts/kconfig/merge_config.sh .config zeroday-fragment.config

# === Must Enable ===
CONFIG_SPI=y
CONFIG_SPI_BCM2835=y
CONFIG_SPI_BCM2835AUX=y
CONFIG_I2C=y
CONFIG_I2C_BCM2835=y
CONFIG_I2C_HID=y
CONFIG_SND=y
CONFIG_SND_BCM2835=y
CONFIG_SND_SOC=y
CONFIG_SND_SOC_ES8389=y
CONFIG_VIDEO_IMX219=y
CONFIG_MEDIA_CONTROLLER=y
CONFIG_MEDIA_CAMERA_SUPPORT=y
CONFIG_V4L2_MEM2MEM=y
# CONFIG_VIDEO_CODEC2 is not set (Android-only, use VIDEO_BCM2835_CODEC instead)
CONFIG_VIDEO_BCM2835_CODEC=y
CONFIG_HWMON=y
CONFIG_BATTERY_BQ27220=y
CONFIG_POWER_SUPPLY=y
CONFIG_RTC_DRV_RX8130=y
CONFIG_BMI270=y
CONFIG_BMI270_I2C=y
CONFIG_IIO=y
CONFIG_IIO_BUFFER=y
CONFIG_IIO_KFIFO_BUF=y
CONFIG_IIO_TRIGGER=y
CONFIG_IIO_TRIGGERED_BUFFER=y
CONFIG_LIRC=y
CONFIG_RC_CORE=y
CONFIG_RC_DEVICES=y
CONFIG_IR_GPIO_TX=y
CONFIG_IR_GPIO_RX=y
CONFIG_USB_CONFIGFS=y
CONFIG_USB_CONFIGFS_HID=y
CONFIG_USB_CONFIGFS_SERIAL=y
CONFIG_USB_CONFIGFS_ACM=y
CONFIG_USB_CONFIGFS_NCM=y
CONFIG_USB_CONFIGFS_MASS_STORAGE=y
CONFIG_USB_CONFIGFS_ECM=y
CONFIG_USB_CONFIGFS_EEM=y
CONFIG_BT=y
CONFIG_BT_BCM=y
CONFIG_BT_HCIUART=y
CONFIG_BT_HCIUART_H4=y
# CONFIG_BT_HCIVHCI is not set (virtual HCI for testing, not needed in production)
CONFIG_CFG80211=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_SDIO=y
CONFIG_NET_VENDOR_REALTEK=y
CONFIG_R8152=y

# === RTL8821CU USB WiFi Dongle ===
CONFIG_USB_NET_DRIVERS=y
CONFIG_USB_USBNET=y
CONFIG_USB_NET_CDCETHER=y
CONFIG_WIRELESS=y
CONFIG_WLAN=y
# CONFIG_88XXCU is not set (out-of-tree, built via DKMS on first boot)
CONFIG_INPUT_MATRIXKMAP=y
CONFIG_INPUT_KEYBOARD=y
CONFIG_KEYBOARD_MATRIX=y
CONFIG_FB=y
CONFIG_FB_BCM2708=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y

# === Must Disable (save RAM/kernel size) ===
# Display: Enable DRM for ST7789v3 panel driver (replaces fbtft)
CONFIG_DRM=y
CONFIG_DRM_PANEL_ILITEK_ILI9341=y
CONFIG_DRM_PANEL_ORIENTATION_QUIRKS=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_V3D=y
CONFIG_SOUND_OSS_CORE=n
# CONFIG_FB_RPISENSEDISPLAY is not set (does not exist in mainline)
CONFIG_USB_PRINTER=n
CONFIG_JOYSTICK=n
CONFIG_HID_LOGITECH=n
CONFIG_HID_LOGITECH_DJ=n
CONFIG_SND_USB_AUDIO=n
CONFIG_SND_USB_CAIAQ=n
CONFIG_V4L_USB_DRIVERS=n
CONFIG_USB_VIDEO_CLASS=n
CONFIG_DVB_USB=n
CONFIG_MEDIA_USB_SUPPORT=n
CONFIG_STAGING_MEDIA=n
CONFIG_ANDROID=n
CONFIG_UEVENT_HELPER=n

# === Size Optimization ===
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# === Security ===
CONFIG_RANDOMIZE_BASE=y
CONFIG_STACKPROTECTOR_STRONG=y
CONFIG_HARDENED_USERCOPY=y
# CONFIG_DEBUG_RODATA is not set (removed in kernel 4.11+, covered by STRICT_KERNEL_RWX)
CONFIG_STRICT_KERNEL_RWX=y