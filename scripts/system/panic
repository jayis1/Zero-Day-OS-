#!/bin/bash
# /usr/local/bin/panic
# ZERO-DAY OS Panic Button
# Kill all offensive tools, wipe history, sanitize screen

PANIC_LOG="/opt/cardputer/panic.log"
TIMESTAMP=$(date '+%Y-%m-%d %H:%M:%S')

echo "[$TIMESTAMP] PANIC TRIGGERED" >> "$PANIC_LOG"

OFFENSIVE_PROCS="aircrack airodump airbase hostapd dnsmasq bettercap nmap
msfconsole msfvenom nikto whatweb sqlmap kismet hcxdumptool hcxping wifite
bt-scan l2ping rfcomm obexftp netcat ncat socat chisel rtl tcpdump
python3 perl ruby ir-replay ir-brute gatttool obexftp rfcomm
cam-snap libcamera libcamera-still libcamera-vid
rtl_power rtl_fm hackrf_transfer"

echo "[PANIC] Killing offensive processes..."
for proc in $OFFENSIVE_PROCS; do
    pkill -9 "$proc" 2>/dev/null
done

echo "[PANIC] Wiping traces..."
history -c 2>/dev/null
history -w 2>/dev/null
rm -f ~/.bash_history /root/.bash_history 2>/dev/null
rm -f /tmp/* 2>/dev/null
rm -rf /opt/cardputer/loot/recon/* 2>/dev/null

echo "[PANIC] Killing tmux sessions..."
tmux kill-server 2>/dev/null

echo "[PANIC] Clearing screen..."
clear
reset
printf '\033[2J\033[H'

echo "[PANIC] Blocking all radios..."
rfkill block all 2>/dev/null

echo "[$TIMESTAMP] PANIC COMPLETE" >> "$PANIC_LOG"

echo "ZERO-DAY OS v0.1 — Login:"
echo "================================"
echo "Password: "