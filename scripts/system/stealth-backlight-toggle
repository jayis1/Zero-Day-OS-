#!/bin/bash
set -euo pipefail
# /usr/local/bin/stealth-backlight-toggle
# Toggle LCD backlight for stealth mode
# Triggered by Fn+Space in i3 config

BACKLIGHT_DIR="/sys/class/backlight"

if [ -d "$BACKLIGHT_DIR" ]; then
    BL_DEV=$(ls "$BACKLIGHT_DIR" | head -1)
    BL_PATH="$BACKLIGHT_DIR/$BL_DEV"
    CURR=$(cat "$BL_PATH/brightness" 2>/dev/null || echo "0")
    MAX=$(cat "$BL_PATH/max_brightness" 2>/dev/null || echo "255")

    if [ "$CURR" -eq 0 ]; then
        echo "$MAX" > "$BL_PATH/brightness" 2>/dev/null
        echo "[+] Backlight ON"
    else
        echo 0 > "$BL_PATH/brightness" 2>/dev/null
        echo "[+] Backlight OFF (stealth)"
    fi
else
    echo "[!] No backlight control found"
fi