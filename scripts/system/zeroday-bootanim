#!/bin/bash
# /usr/local/bin/zeroday-bootanim
# Boot animation for ZERO-DAY OS — glitch ASCII art on ST7789v3 LCD
# Plays during boot before Xorg/i3 launches
# Called by zeroday-boot before startx

# Detect if we're on a real display
TTY=$(tty)
if [[ "$TTY" != *tty* ]] && [[ "$TTY" != *pts* ]]; then
    # Not on a TTY, skip animation
    exit 0
fi

# Animation speed (seconds between frames)
GLITCH_DELAY=${1:-0.03}
BANNER_DELAY=${2:-0.08}

# Colors
R='\033[31m'   # Red
G='\033[32m'   # Green
C='\033[36m'   # Cyan
Y='\033[33m'   # Yellow
B='\033[1m'    # Bold
D='\033[2m'    # Dim
NC='\033[0m'   # Reset
BG='\033[40m'  # Black bg
BLINK='\033[5m' # Blink

# Clear screen and hide cursor
clear
tput civis 2>/dev/null

# Helper: print centered text
center() {
    local text="$1"
    local cols=$(tput cols 2>/dev/null || echo 40)
    local padding=$(( (cols - ${#text}) / 2 ))
    [ $padding -lt 0 ] && padding=0
    printf '%*s' $padding ''
    echo -e "$text"
}

# Phase 1: Static/glitch noise (1-2 seconds)
phase_glitch() {
    local chars='▓▒░█▄▀■║╔╗╚╝░▒▓µ§½±÷°·'
    local cols=$(tput cols 2>/dev/null || echo 40)
    local lines=$(tput lines 2>/dev/null || echo 18)

    for frame in $(seq 1 15); do
        clear
        for y in $(seq 1 $((lines - 4))); do
            line=""
            for x in $(seq 1 $cols); do
                if [ $((RANDOM % 5)) -eq 0 ]; then
                    char="${chars:$((RANDOM % ${#chars})):1}"
                    if [ $((RANDOM % 10)) -eq 0 ]; then
                        line="${line}${R}${char}${NC}"
                    elif [ $((RANDOM % 10)) -eq 0 ]; then
                        line="${line}${C}${char}${NC}"
                    else
                        line="${line}${G}${char}${NC}"
                    fi
                else
                    line="${line} "
                fi
            done
            echo -e "$line"
        done
        sleep "$GLITCH_DELAY"
    done
}

# Phase 2: Glitch reveal — ASCII banner fragments appear and corrupt
phase_glitch_banner() {
    local banner=(
        "${C} ███████╗${NC} ███████╗██████╗ ███████╗██████╗ "
        "${C} ╚══███╔╝${NC} ██╔════╝██╔══██╗██╔════╝██╔══██╗"
        "${C}   ███╔╝ ${NC} █████╗  ██║  ██║█████╗  ██████╔╝"
        "${C}  ███╔╝  ${NC} ██╔══╝  ██║  ██║██╔══╝  ██╔══██╗"
        "${C} ███████╗${NC} ███████╗██████╔╝███████╗██║  ██║"
        "${C} ╚══════╝${NC} ╚══════╝╚═════╝ ╚══════╝╚═╝  ╚═╝"
    )

    # Glitch each line: show corrupted then correct
    for line in "${banner[@]}"; do
        # Show corrupted version
        corrupted=$(echo "$line" | tr '█╗╚╝═╔░▒▓' '▓░╔╗═╚█▒░▄' | head -c 40)
        center "${R}${corrupted}${NC}"
        sleep 0.05
        # Flash correct version
        clear
        for prev in "${banner[@]}"; do
            if [ "$prev" = "$line" ]; then
                center "${B}${G}${prev}${NC}"
            else
                center "${D}${prev}${NC}"
            fi
        done
        sleep 0.02
    done

    # Final banner with flicker
    for flick in $(seq 1 3); do
        clear
        for line in "${banner[@]}"; do
            center "${B}${line}${NC}"
        done
        sleep 0.06
        clear
        for line in "${banner[@]}"; do
            center "${D}${line}${NC}"
        done
        sleep 0.03
    done

    # Stable banner
    clear
    for line in "${banner[@]}"; do
        center "${B}${C}${line}${NC}"
    done
}

# Phase 3: Subsystem boot sequence (typing effect)
phase_boot_sequence() {
    local subsystems=(
        "${G}[  OK  ]${NC}  Kernel: BCM2837 quad-core initialized"
        "${G}[  OK  ]${NC}  Memory: 512MB LPDDR2 mapped"
        "${G}[  OK  ]${NC}  Display: ST7789v3 320×240 framebuffer active"
        "${G}[  OK  ]${NC}  Input: Cardputer keyboard matrix online"
        "${Y}[ .... ]${NC}  Radio: WiFi/BT blocked (stealth default)"
        "${G}[  OK  ]${NC}  Power: BQ27220 fuel gauge reporting 98%"
        "${G}[  OK  ]${NC}  IMU: BMI270 motion sensor ready"
        "${G}[  OK  ]${NC}  Audio: ES8389 codec initialized"
        "${G}[  OK  ]${NC}  RTC: RX8130CE clock synced"
        "${G}[  OK  ]${NC}  IR: Transceiver module standing by"
        "${Y}[ .... ]${NC}  Dongle: RTL8821CU not connected"
        "${G}[  OK  ]${NC}  USB: Gadget mode available (usb-gadget-mode)"
        "${G}[  OK  ]${NC}  Tamper: BMI270 motion daemon started"
        "${G}[  OK  ]${NC}  Loot: /opt/cardputer/loot ready"
    )

    echo ""
    echo ""
    for line in "${subsystems[@]}"; do
        # Typing effect
        display=""
        for (( i=0; i<${#line}; i++ )); do
            display="${line:0:$((i+1))}"
            # Move to start of line, clear, and reprint
            printf "\r%s" "$display"
            sleep 0.005
        done
        echo ""
        sleep 0.06
    done
}

# Phase 4: Warning banner
phase_warning() {
    echo ""
    sleep 0.3
    center "${B}${R}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    sleep 0.1
    center "${B}${R}  ⚠  AUTHORIZED USE ONLY  ⚠${NC}"
    sleep 0.1
    center "${B}${Y}  This system is for penetration testing${NC}"
    sleep 0.05
    center "${B}${Y}  on networks you own or have permission${NC}"
    sleep 0.05
    center "${B}${Y}  to test. Unauthorized access is illegal.${NC}"
    sleep 0.1
    center "${B}${R}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    sleep 0.3
}

# Phase 5: Ready prompt
phase_ready() {
    echo ""
    echo ""
    center "${B}${G}▸ Z E R O - D A Y   O S   R E A D Y${NC}"
    echo ""
    center "${D}Fn+Tab: TUI  │  Fn+P: Panic  │  Fn+O: OpenCode${NC}"
    echo ""
    center "${D}All radios OFF — use wifi-toggle / bt-toggle to enable${NC}"
    echo ""

    # Blinking cursor
    for blink in $(seq 1 4); do
        printf "  ${G}█${NC}"
        sleep 0.4
        printf "\b \b"
        sleep 0.4
    done
    echo ""
}

# Phase 6: Random glitch effect (subtle)
phase_final_glitch() {
    # Quick screen tear effect
    for i in $(seq 1 2); do
        clear
        sleep 0.01
        printf '\033[3;1H'
        echo -e "${R}▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀${NC}"
        sleep 0.02
        clear
        printf '\033[15;1H'
        echo -e "${C}▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄${NC}"
        sleep 0.02
    done
    clear
}

# ── Main Animation Sequence ──────────────────────────────

# Check if bootanim is disabled
if [ -f /etc/zeroday/no-bootanim ] || echo "$ZERODAY_NO_BOOTANIM" | grep -qi "1\|true\|yes"; then
    exit 0
fi

# Phase 1: Glitch noise
phase_glitch

# Phase 2: Banner reveal
clear
phase_glitch_banner
sleep 0.2

# Phase 3: Boot sequence
phase_boot_sequence
sleep 0.1

# Phase 4: Warning
phase_warning

# Phase 5: Ready
phase_ready

# Phase 6: Final glitch
phase_final_glitch

# Restore cursor
tput cnorm 2>/dev/null

echo ""
echo -e "${G}[zeroday-boot]${NC} Launching desktop..."
sleep 0.5