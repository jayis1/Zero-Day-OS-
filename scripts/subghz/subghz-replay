#!/bin/bash
set -euo pipefail
# /usr/local/bin/subghz-replay
# Replay captured Sub-GHz radio signals
# Usage: subghz-replay <signal_file> [frequency_mhz] [repeats]
#
# WARNING: Only replay signals you own or have authorization to transmit.
# Unauthorized transmission on regulated frequencies may be illegal.

SIGNAL_FILE="$1"
FREQ="${2:-433.920}"
REPEATS="${3:-3}"
LOOT="/opt/cardputer/loot/rf"

if [ -z "$SIGNAL_FILE" ]; then
    echo "Usage: subghz-replay <signal_file> [frequency_mhz] [repeats]"
    echo ""
    echo "Replay a captured Sub-GHz signal."
    echo ""
    echo "WARNING: Only transmit on frequencies you are authorized to use."
    echo ""
    echo "Captured signals:"
    ls -la "$LOOT"/subghz_*.raw "$LOOT"/subghz_*.json 2>/dev/null || echo "  (none found)"
    exit 1
fi

if [ ! -f "$SIGNAL_FILE" ]; then
    echo "[!] File not found: $SIGNAL_FILE"
    exit 1
fi

if [ "$(id -u)" -ne 0 ]; then
    echo "[!] Root required for radio transmission."
    exit 1
fi

echo "[*] ZERO-DAY OS — Sub-GHz Signal Replay"
echo "[*] File: $SIGNAL_FILE"
echo "[*] Frequency: ${FREQ}MHz"
echo "[*] Repeats: $REPEATS"
echo ""
echo "[!] WARNING: Ensure you are authorized to transmit on ${FREQ}MHz."
echo ""
read -p "Continue? [y/N] " CONFIRM
if [ "$CONFIRM" != "y" ] && [ "$CONFIRM" != "Y" ]; then
    echo "[*] Cancelled."
    exit 0
fi

if command -v rfcat &>/dev/null; then
    echo "[*] Using YardStick One (rfcat)..."
    for i in $(seq 1 "$REPEATS"); do
        echo "[*] Transmitting attempt $i/$REPEATS..."
        rfcat -t "$SIGNAL_FILE" -f "${FREQ}e6" 2>/dev/null
        sleep 0.5
    done
    echo "[+] Signal replayed $REPEATS times on ${FREQ}MHz"

elif python3 -c "import cc1101" 2>/dev/null; then
    echo "[*] Using CC1101 on SPI..."
    python3 << PYEOF
import cc1101, time

radio = cc1101.CC1101()
radio.reset()
radio.set_frequency(${FREQ} * 1e6)
radio.set_modem_format(cc1101.ModemFormat.ASK_OOK)

with open("${SIGNAL_FILE}", "rb") as f:
    data = f.read()

if data:
    for i in range(${REPEATS}):
        print(f"[*] Transmitting attempt {i+1}/${REPEATS}...")
        radio.transmit_bytes(data)
        time.sleep(0.5)
    print(f"[+] Signal replayed ${REPEATS} times on ${${FREQ}}MHz")
else:
    print("[!] No data in signal file")
PYEOF

else
    echo "[!] No Sub-GHz transmitter hardware found."
    echo "[!] Install YardStick One (rfcat) or CC1101 SPI (cc1101)"
fi